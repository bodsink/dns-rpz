# DNS-RPZ bootstrap config
# Copy this file to dns-rpz.conf and fill in your values.
# Lines starting with # are comments. Format: KEY=VALUE

# -------------------------------------------------------
# Database (required)
# -------------------------------------------------------
DATABASE_DSN=postgres://dnsrpz:secret@localhost:5432/dnsrpz
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2

# -------------------------------------------------------
# Server listen addresses (required)
# -------------------------------------------------------
DNS_ADDRESS=0.0.0.0:53
HTTP_ADDRESS=0.0.0.0:8080

# -------------------------------------------------------
# RPZ settings (optional, defaults shown)
# -------------------------------------------------------
# Upstream DNS resolvers for non-blocked queries (recursion)
# Comma-separated list of IP:port
DNS_UPSTREAM=8.8.8.8:53,8.8.4.4:53

# Strategy for distributing queries across upstreams:
#   roundrobin - rotate through servers in order (with fallback)
#   random     - pick a random server each time (with fallback)
#   race       - send to ALL servers simultaneously, use fastest response
DNS_UPSTREAM_STRATEGY=roundrobin

# Upstream response cache size (number of entries).
# Caches NOERROR and NXDOMAIN responses from upstream; TTL is respected per RFC.
# Set to 0 to disable caching. Default: 100000 (~60-80% hit rate at 10M queries/day).
DNS_CACHE_SIZE=100000

# Audit log: when enabled, every DNS query is logged at INFO level regardless of LOG_LEVEL.
# Each log line contains: client IP, domain name, query type, and result (allowed/blocked/refused).
# WARNING: at 10M queries/day this produces ~1.5GB/day of logs. Enable LOG_FILE=true and
# configure logrotate (/etc/logrotate.d/dns-rpz) to rotate daily and keep 7 days.
# Default: false
DNS_AUDIT_LOG=false

# Action applied when a domain matches an RPZ entry but has no explicit CNAME policy record:
#   nxdomain - return NXDOMAIN (domain does not exist)
#   nodata   - return NODATA (no records of the requested type)
RPZ_DEFAULT_ACTION=nxdomain

# -------------------------------------------------------
# Logging (optional, defaults shown)
# -------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=text

# LOG_FILE: set to true to write logs to a file in addition to stdout
# LOG_FILE_PATH: path to log file (default: dns-rpz.log), only used when LOG_FILE=true
LOG_FILE=false
#LOG_FILE_PATH=dns-rpz.log
